{
    "name": "archipro/silverstripe-smart-enum",
    "description": "Silverstripe CMS DBField backed by PHP 8.1 BackedEnums with optional VARCHAR storage",
    "type": "silverstripe-vendormodule",
    "keywords": [
        "silverstripe",
        "CMS",
        "enum"
    ],
    "license": "BSD-3-Clause",
    "require": {
        "php": "^8.1",
        "silverstripe/framework": "^5.0||^4.13"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "squizlabs/php_codesniffer": "^3.7",
        "silverstripe/standards": "^1",
        "phpstan/extension-installer": "^1.3"
    },
    "autoload": {
        "psr-4": {
            "ArchiPro\\Silverstripe\\SmartEnum\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ArchiPro\\Silverstripe\\SmartEnum\\Tests\\": "tests/php/"
        }
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "silverstripe/vendor-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
