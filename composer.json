{
    "name": "archipro/silverstripe-smart-enum",
    "description": "Silverstripe CMS DBField backed by PHP 8.1 BackedEnums with optional VARCHAR storage",
    "type": "silverstripe-vendormodule",
    "keywords": [
        "silverstripe",
        "CMS",
        "enum"
    ],
    "license": "BSD-3-Clause",
    "require": {
        "php": "^8.1",
        "silverstripe/framework": "^5.0||^4.13"
    },
    "require-dev": {
        "cambis/silverstan": "^2.1 <2.2",
        "phpstan/extension-installer": "^1.3",
        "phpstan/phpstan": "^2.2",
        "phpunit/phpunit": "^9.6",
        "silverstripe/standards": "^1",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse --memory-limit=1G",
        "phpcs": "phpcs",
        "lint": "@phpcs",
        "check": [
            "@phpstan",
            "@phpcs",
            "@test"
        ]
    },
    "autoload": {
        "psr-4": {
            "ArchiPro\\Silverstripe\\SmartEnum\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ArchiPro\\Silverstripe\\SmartEnum\\Tests\\": "tests/php/"
        }
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "silverstripe/vendor-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
