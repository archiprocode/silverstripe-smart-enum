parameters:
  paths:
    - src
    - tests
  ignoreErrors:
    # Unit tests construct DB fields directly; Injector::create() needs a full SS bootstrap.
    -
      identifier: silverstan.injectable.useCreate
      path: tests/php/*
    # Factory constructs DBSmartEnum directly; Injector::create() is not appropriate here.
    -
      identifier: silverstan.injectable.useCreate
      path: src/DBSmartEnumFactory.php
